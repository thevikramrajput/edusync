# ─── EduSync Backend — .env.example ──────────────────────
# Copy to .env and fill in your values.

SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=edusync.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://edusync:edusync_secure_2026@db:5432/edusync_db

# CORS
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_URL=admin/

# Docker PostgreSQL
POSTGRES_DB=edusync_db
POSTGRES_USER=edusync
POSTGRES_PASSWORD=edusync_secure_2026
